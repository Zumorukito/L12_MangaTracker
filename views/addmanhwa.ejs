<!DOCTYPE html>
<html lang="en">

<head>
    <title>Add Manhwa</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .sidebar {
            width: 220px;
            min-height: calc(100vh - 65px);
            border-right: 1px solid #ccc;
        }

        .sidebar a {
            display: block;
            padding: 20px;
            text-decoration: none;
            color: black;
            border-bottom: 1px solid #ccc;
            font-size: 18px;
        }

        .content {
            flex: 1;
            padding: 30px;
        }

        .cover-box {
            width: 180px;
            height: 240px;
            border: 1px solid #999;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8f9fa;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm bg-light border-bottom">
        <div class="container-fluid">

            <a class="navbar-brand d-flex align-items-center" href="/">
                <span class="me-3 fs-3">☰</span>
                <span class="fs-4">Title</span>
            </a>

            <form class="d-flex ms-auto" action="/" method="GET">
                <input class="form-control me-2" type="text" name="search" placeholder="Search input">

                <button class="btn btn-outline-dark me-2" type="submit">
                    Search
                </button>

                <a href="/addmanhwa" class="btn btn-outline-dark">+ Add</a>
            </form>

        </div>
    </nav>

    <!-- Main layout -->
    <div class="d-flex">

        <!-- Sidebar -->
        <div class="sidebar">
            <a href="/">Home</a>
            <a href="/completed">Completed</a>
            <a href="/addmanhwa">+ Add</a>
        </div>

        <!-- Content -->
        <div class="content">

            <h2 class="text-center mb-4">Add Page</h2>

            <form action="/addmanhwa" method="POST" enctype="multipart/form-data">

                <div class="row">

                    <!-- Left side form -->
                    <div class="col-md-8">

                        <h4>Title</h4>

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Chapter</label>
                            <input type="number" name="chapter" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-control" required>
                                <option value="Reading">Reading</option>
                                <option value="Completed">Completed</option>
                                <option value="Planned">Planned</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Cover Image</label>
                            <input type="file" name="image" class="form-control" accept="image/*" required>
                        </div>

                    </div>

                    <!-- Right side image area -->
                    <div class="col-md-4">

                        <label class="form-label">Cover Image</label>

                        <div class="cover-box mb-3">
                            Image
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-2">Save</button>
                        <a href="/" class="btn btn-secondary w-100">Cancel</a>

                    </div>

                </div>

            </form>

        </div>

    </div>

</body>

</html>