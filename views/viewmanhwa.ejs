<!DOCTYPE html>
<html lang="en">
<head>
    <title>View Manhwa</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .sidebar {
            width: 220px;
            min-height: calc(100vh - 65px);
            border-right: 1px solid #ccc;
        }

        .sidebar a {
            display: block;
            padding: 20px;
            text-decoration: none;
            color: black;
            border-bottom: 1px solid #ccc;
            font-size: 18px;
        }

        .sidebar a:hover {
            background-color: #f2f2f2;
        }

        .content {
            flex: 1;
            padding: 30px;
        }

        .cover-img {
            width: 160px;
            height: 220px;
            object-fit: cover;
            border: 1px solid #999;
        }

        .detail-box {
            border-bottom: 1px solid #ccc;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .info-box {
            border: 1px solid #ccc;
            padding: 15px;
            min-height: 80px;
        }

        .back-link {
            font-size: 35px;
            text-decoration: none;
            color: black;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm bg-light border-bottom">
        <div class="container-fluid">

            <a class="navbar-brand d-flex align-items-center" href="/">
                <span class="me-3 fs-3">☰</span>
                <span class="fs-4">Title</span>
            </a>

            <form class="d-flex ms-auto" action="/" method="GET">
                <input class="form-control me-2" type="text" name="search" placeholder="Search input">

                <button class="btn btn-outline-dark me-2" type="submit">Search</button>

                <a href="/addmanhwa" class="btn btn-outline-dark">+ Add</a>
            </form>

        </div>
    </nav>

    <!-- Main layout -->
    <div class="d-flex">

        <!-- Sidebar -->
        <div class="sidebar">
            <a href="/">Home</a>
            <a href="/completed">Completed</a>
            <a href="/addmanhwa">+ Add</a>
        </div>

        <!-- Detail Content -->
        <div class="content">

            <h2 class="text-center mb-4">Detail Page</h2>

            <% if (manhwa) { %>

                <div class="detail-box">

                    <div class="d-flex justify-content-between align-items-start">

                        <div class="d-flex">

                            <!-- Back arrow -->
                            <a href="/" class="back-link me-3">←</a>

                            <!-- Cover image -->
                            <img src="<%= manhwa.image %>" class="cover-img me-4" alt="<%= manhwa.name %>">

                            <!-- Main info -->
                            <div>
                                <h3><%= manhwa.name %></h3>
                                <p class="fs-5 mb-1">Chapter: <%= manhwa.chapter %></p>
                                <p class="fs-5 mb-1">Status: <%= manhwa.status %></p>
                            </div>

                        </div>

                        <!-- Three dots area -->
                        <div class="fs-3">
                            ⋮
                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <h5>Reading Progress</h5>
                        <div class="info-box">
                            You are currently at Chapter <%= manhwa.chapter %>.
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <h5>Manhwa Details</h5>
                        <div class="info-box">
                            <p class="mb-1"><strong>Name:</strong> <%= manhwa.name %></p>
                            <p class="mb-1"><strong>Status:</strong> <%= manhwa.status %></p>
                            <p class="mb-0"><strong>Chapter:</strong> <%= manhwa.chapter %></p>
                        </div>
                    </div>

                </div>

                <div class="d-flex gap-2 mt-3">
                    <a href="/editmanhwa/<%= manhwa.id %>" class="btn btn-outline-primary">Edit</a>

                    <form action="/deletemanhwa/<%= manhwa.id %>" method="POST">
                        <button type="submit" class="btn btn-outline-danger">Delete</button>
                    </form>

                    <a href="/" class="btn btn-secondary">Back</a>
                </div>

            <% } else { %>

                <p>Manhwa not found.</p>
                <a href="/" class="btn btn-secondary">Back to Home</a>

            <% } %>

        </div>

    </div>

</body>
</html>