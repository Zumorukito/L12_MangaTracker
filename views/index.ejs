<!DOCTYPE html>
<html lang="en">

<head>
    <title>
        <%= pageTitle %>
    </title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .sidebar {
            width: 220px;
            min-height: calc(100vh - 65px);
            border-right: 1px solid #ccc;
        }

        .sidebar a {
            display: block;
            padding: 20px;
            text-decoration: none;
            color: black;
            border-bottom: 1px solid #ccc;
            font-size: 18px;
        }

        .sidebar a:hover {
            background-color: #f2f2f2;
        }

        .content {
            flex: 1;
            padding: 25px;
        }

        .manhwa-card {
            border: 1px solid #ccc;
            padding: 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .manhwa-img {
            width: 80px;
            height: 110px;
            object-fit: cover;
            border: 1px solid #999;
            margin-right: 15px;
        }
    </style>
</head>

<body>
    <header>
        <%- include('partials/navbar.ejs') %>
    </header>
    <div class="d-flex">

        <div class="sidebar">
            <a href="/">Home</a>
            <a href="/completed">Completed</a>
            <a href="/addmanhwa">+ Add</a>
        </div>

        <div class="content">
            <h3>
                <%= pageTitle %>
            </h3>

            <% if (manhwaList.length===0) { %>
                <p>No manhwa found.</p>
                <% } %>

                    <% manhwaList.forEach(manhwa=> { %>
                        <div class="manhwa-card">

                            <div class="d-flex align-items-center">
                                <img src="<%= manhwa.image %>" class="manhwa-img" alt="<%= manhwa.name %>">

                                <div>
                                    <h5 class="mb-1">
                                        <%= manhwa.name %>
                                    </h5>
                                    <p class="mb-1">Chapter: <%= manhwa.chapter %>
                                    </p>
                                    <p class="mb-0">Status: <%= manhwa.status %>
                                    </p>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <a href="/viewmanhwa/<%= manhwa.id %>" class="btn btn-sm btn-outline-dark">View</a>
                                <a href="/editmanhwa/<%= manhwa.id %>" class="btn btn-sm btn-outline-primary">Edit</a>

                                <form action="/deletemanhwa/<%= manhwa.id %>" method="POST">
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>

                        </div>
                        <% }) %>
        </div>
    </div>
</body>
</html>